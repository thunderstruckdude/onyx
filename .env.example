NODE_ENV=development
PORT=4000

# Mongo replica-set URI (required for transactions)
MONGODB_URI=mongodb://127.0.0.1:27017/auction?replicaSet=rs0

# JWT
JWT_ACCESS_SECRET=replace-with-long-random-secret
JWT_ACCESS_TTL=15m
JWT_ISSUER=secure-auction-backend

# Browser / cookie
CORS_ORIGIN=http://localhost:5173
COOKIE_DOMAIN=

# Payments (optional in dev; required for live webhooks)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
